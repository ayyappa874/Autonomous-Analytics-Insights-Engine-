    "def layer1_data_input_and_understanding(csv_path: str) -> Dict[str, Any]:\n",
    "    \"\"\"Layer 1 – load CSV, detect schema, profile data, build metadata summary.\"\"\"\n",
    "    df_raw = pd.read_csv(csv_path)\n",
    "\n",
    "    # Schema\n",
    "    dtypes = df_raw.dtypes.astype(str).to_dict()\n",
    "    columns = list(df_raw.columns)\n",
    "\n",
    "    # Missing values\n",
    "    missing = df_raw.isnull().sum().to_dict()\n",
    "    missing_pct = (df_raw.isnull().mean() * 100).round(2).to_dict()\n",
    "\n",
    "    # Duplicates\n",
    "    total_rows = len(df_raw)\n",
    "    dup_count = df_raw.duplicated().sum()\n",
    "    dup_pct = round(100 * dup_count / total_rows, 2) if total_rows > 0 else 0.0\n",
    "\n",
    "    # Sample rows\n",
    "    sample_rows = df_raw.head(5).to_dict(orient=\"records\")\n",
    "\n",
    "    # Basic numeric stats\n",
    "    try:\n",
    "        numeric_desc = df_raw.describe(include=[np.number]).to_dict()\n",
    "    except Exception:\n",
    "        numeric_desc = {}\n",
    "\n",
    "    # Basic categorical stats\n",
    "    try:\n",
    "        cat_desc = df_raw.describe(include=[\"object\", \"category\"]).to_dict()\n",
    "    except Exception:\n",
    "        cat_desc = {}\n",
    "\n",
    "    metadata = {\n",
    "        \"shape\": {\"rows\": total_rows, \"columns\": len(columns)},\n",
    "        \"columns\": columns,\n",
    "        \"dtypes\": dtypes,\n",
    "        \"missing_counts\": missing,\n",
    "        \"missing_pct\": missing_pct,\n",
    "        \"duplicate_count\": int(dup_count),\n",
    "        \"duplicate_pct\": dup_pct,\n",
    "        \"sample_rows\": sample_rows,\n",
    "        \"numeric_summary\": numeric_desc,\n",
    "        \"categorical_summary\": cat_desc,\n",
    "    }\n",
    "\n",
    "    return {\"df_raw\": df_raw, \"metadata\": metadata}\n"
   ]
