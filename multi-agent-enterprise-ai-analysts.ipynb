    "def compute_kpis(df: pd.DataFrame) -> Dict[str, Any]:\n",
    "    \"\"\"KPI Engine – totals, averages, unique counts for numeric & categorical.\"\"\"\n",
    "    kpis = {}\n",
    "\n",
    "    numeric_cols = df.select_dtypes(include=[np.number]).columns.tolist()\n",
    "    cat_cols = df.select_dtypes(include=[\"object\", \"category\"]).columns.tolist()\n",
    "\n",
    "    numeric_stats = {}\n",
    "    for col in numeric_cols:\n",
    "        series = df[col]\n",
    "        numeric_stats[col] = {\n",
    "            \"mean\": float(series.mean()),\n",
    "            \"median\": float(series.median()),\n",
    "            \"min\": float(series.min()),\n",
    "            \"max\": float(series.max()),\n",
    "            \"sum\": float(series.sum()),\n",
    "            \"std\": float(series.std() if series.std() == series.std() else 0.0),\n",
    "            \"non_null_count\": int(series.count()),\n",
    "        }\n",
    "\n",
    "    categorical_stats = {}\n",
    "    for col in cat_cols:\n",
    "        series = df[col].astype(str)\n",
    "        top_values = series.value_counts().head(5).to_dict()\n",
    "        categorical_stats[col] = {\n",
    "            \"unique_count\": int(series.nunique()),\n",
    "            \"top_values\": top_values,\n",
    "        }\n",
    "\n",
    "    kpis[\"numeric_stats\"] = numeric_stats\n",
    "    kpis[\"categorical_stats\"] = categorical_stats\n",
    "    kpis[\"row_count\"] = int(len(df))\n",
    "    kpis[\"column_count\"] = int(len(df.columns))\n",
    "\n",
    "    return kpis\n"
   ]
  },
