    "def detect_datetime_column(df: pd.DataFrame) -> Optional[str]:\n",
    "    \"\"\"Try to detect a datetime-like column.\"\"\"\n",
    "    for col in df.columns:\n",
    "        if \"date\" in col.lower() or \"time\" in col.lower():\n",
    "            try:\n",
    "                pd.to_datetime(df[col])\n",
    "                return col\n",
    "            except Exception:\n",
    "                continue\n",
    "    # fallback: try any column that can be parsed\n",
    "    for col in df.columns:\n",
    "        try:\n",
    "            pd.to_datetime(df[col])\n",
    "            return col\n",
    "        except Exception:\n",
    "            continue\n",
    "    return None\n",
    "\n",
    "\n",
    "def compute_trends(df: pd.DataFrame) -> Dict[str, Any]:\n",
    "    \"\"\"Trend Analyzer – monthly/weekly aggregations if a datetime column exists.\"\"\"\n",
    "    trends = {\"datetime_column\": None, \"monthly\": {}, \"weekly\": {}}\n",
    "\n",
    "    dt_col = detect_datetime_column(df)\n",
    "    if dt_col is None:\n",
    "        return trends\n",
    "\n",
    "    trends[\"datetime_column\"] = dt_col\n",
    "\n",
    "    df_ts = df.copy()\n",
    "    df_ts[dt_col] = pd.to_datetime(df_ts[dt_col], errors=\"coerce\")\n",
    "    df_ts = df_ts.dropna(subset=[dt_col])\n",
    "    if df_ts.empty:\n",
    "        return trends\n",
    "\n",
    "    df_ts = df_ts.set_index(dt_col)\n",
    "    numeric_cols = df_ts.select_dtypes(include=[np.number]).columns\n",
    "\n",
    "    if len(numeric_cols) == 0:\n",
    "        return trends\n",
    "\n",
    "    # Monthly trends\n",
    "    monthly = df_ts[numeric_cols].resample(\"M\").mean().reset_index()\n",
    "    trends[\"monthly\"] = {\n",
    "        \"index_name\": dt_col,\n",
    "        \"data\": monthly.to_dict(orient=\"records\"),\n",
    "    }\n",
    "\n",
    "    # Weekly trends\n",
    "    weekly = df_ts[numeric_cols].resample(\"W\").mean().reset_index()\n",
    "    trends[\"weekly\"] = {\n",
    "        \"index_name\": dt_col,\n",
    "        \"data\": weekly.to_dict(orient=\"records\"),\n",
    "    }\n",
    "\n",
    "    return trends\n"
   ]
  },
