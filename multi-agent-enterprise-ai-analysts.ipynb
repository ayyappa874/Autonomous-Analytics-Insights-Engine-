    "import matplotlib.pyplot as plt\n",
    "from matplotlib.patches import FancyBboxPatch, FancyArrowPatch\n",
    "\n",
    "def draw_box(ax, xy, width, height, text, fontsize=9):\n",
    "    x, y = xy\n",
    "    box = FancyBboxPatch(\n",
    "        (x, y),\n",
    "        width,\n",
    "        height,\n",
    "        boxstyle=\"round,pad=0.3\",\n",
    "        edgecolor=\"black\",\n",
    "        facecolor=\"white\"\n",
    "    )\n",
    "    ax.add_patch(box)\n",
    "    ax.text(\n",
    "        x + width / 2,\n",
    "        y + height / 2,\n",
    "        text,\n",
    "        ha=\"center\",\n",
    "        va=\"center\",\n",
    "        fontsize=fontsize,\n",
    "        wrap=True\n",
    "    )\n",
    "\n",
    "def draw_arrow(ax, start_xy, end_xy):\n",
    "    start_x, start_y = start_xy\n",
    "    end_x, end_y = end_xy\n",
    "    arrow = FancyArrowPatch(\n",
    "        (start_x, start_y),\n",
    "        (end_x, end_y),\n",
    "        arrowstyle=\"->\",\n",
    "        mutation_scale=15\n",
    "    )\n",
    "    ax.add_patch(arrow)\n",
    "\n",
    "# ==== CREATE DIAGRAM ====\n",
    "\n",
    "fig, ax = plt.subplots(figsize=(14, 6))\n",
    "\n",
    "box_w = 1.8\n",
    "box_h = 0.8\n",
    "y_mid = 0\n",
    "\n",
    "# Main pipeline boxes (left → right)\n",
    "csv_pos      = (0.0,       y_mid)\n",
    "layer1_pos   = (2.3,       y_mid)\n",
    "layer2_pos   = (4.6,       y_mid)\n",
    "context_pos  = (6.9,       y_mid)\n",
    "client_pos   = (9.2,       y_mid)\n",
    "\n",
    "draw_box(ax, csv_pos,     box_w, box_h, \"/kaggle/input/multi-agent-enterprise-ai-analyst/enterprise_sales_dataset.csv\\n(raw data)\")\n",
    "draw_box(ax, layer1_pos,  box_w, box_h, \"layer1_data_input_\\nand_understanding\\n(df_raw, metadata)\")\n",
    "draw_box(ax, layer2_pos,  box_w, box_h, \"layer2_analytical_\\nprocessing\\n(df_clean, analytics)\")\n",
    "draw_box(ax, context_pos, box_w, box_h, \"build_text_context_\\nfor_llm\\n(text context)\")\n",
    "draw_box(ax, client_pos,  box_w, box_h, \"RealLLMClient\\n(Gemini model)\")\n",
    "\n",
    "# Arrows along main pipeline\n",
    "draw_arrow(\n",
    "    ax,\n",
    "    (csv_pos[0] + box_w, csv_pos[1] + box_h / 2),\n",
    "    (layer1_pos[0],      layer1_pos[1] + box_h / 2)\n",
    ")\n",
    "\n",
    "draw_arrow(\n",
    "    ax,\n",
    "    (layer1_pos[0] + box_w, layer1_pos[1] + box_h / 2),\n",
    "    (layer2_pos[0],        layer2_pos[1] + box_h / 2)\n",
    ")\n",
    "\n",
    "draw_arrow(\n",
    "    ax,\n",
    "    (layer2_pos[0] + box_w, layer2_pos[1] + box_h / 2),\n",
    "    (context_pos[0],        context_pos[1] + box_h / 2)\n",
    ")\n",
    "\n",
    "draw_arrow(\n",
    "    ax,\n",
    "    (context_pos[0] + box_w, context_pos[1] + box_h / 2),\n",
