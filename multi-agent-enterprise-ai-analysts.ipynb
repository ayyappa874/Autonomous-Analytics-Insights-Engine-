    "def run_enterprise_ai_analyst_agent(\n",
    "    csv_path: str,\n",
    "    llm_client: RealLLMClient,\n",
    ") -> Dict[str, Any]:\n",
    "    \"\"\"\n",
    "    Full 4-layer Enterprise AI Analyst Agent (Multi-Agent Version):\n",
    "    1) Data input & understanding\n",
    "    2) Analytical processing (cleaning, KPIs, trends, anomalies)\n",
    "    3) Multi-agent AI reasoning (EDA, ML, Narrative/BI)\n",
    "    4) Output packaging (reports, viz suggestions, portfolio narrative)\n",
    "    \"\"\"\n",
    "    # Layer 1\n",
    "    l1 = layer1_data_input_and_understanding(csv_path)\n",
    "    df_raw = l1[\"df_raw\"]\n",
    "    metadata = l1[\"metadata\"]\n",
    "\n",
    "    # Layer 2\n",
    "    l2 = layer2_analytical_processing(df_raw)\n",
    "    df_clean = l2[\"df_clean\"]\n",
    "    analytics = l2[\"analytics\"]\n",
    "\n",
    "    # Layer 3 – Multi-Agent\n",
    "    l3 = layer3_multi_agent_reasoning(llm_client, metadata, analytics)\n",
    "    ai_insights = l3\n",
    "\n",
    "    # Layer 4 – Multi-Agent Outputs\n",
    "    l4 = layer4_output_generation_multi_agent(ai_insights, metadata, analytics)\n",
    "\n",
    "    debug = {\n",
    "        \"csv_path\": csv_path,\n",
    "        \"rows_raw\": len(df_raw),\n",
    "        \"rows_clean\": len(df_clean),\n",
    "        \"columns\": list(df_clean.columns),\n",
    "    }\n",
    "\n",
    "    return {\n",
    "        \"df_raw\": df_raw,\n",
    "        \"df_clean\": df_clean,\n",
    "        \"metadata\": metadata,\n",
    "        \"analytics\": analytics,\n",
    "        \"ai_insights\": ai_insights,   # all 3 agents + combined\n",
    "        \"outputs\": l4,                # executive + combined + viz suggestions\n",
    "        \"debug\": debug,\n",
    "    }\n"
   ]
  },
