    "def detect_anomalies(df: pd.DataFrame, z_thresh: float = 3.0) -> Dict[str, Any]:\n",
    "    \"\"\"Anomaly Detector – simple Z-score based outlier detection for numeric columns.\"\"\"\n",
    "    anomalies = {}\n",
    "    num_df = df.select_dtypes(include=[np.number])\n",
    "\n",
    "    if num_df.empty:\n",
    "        return {\"columns\": {}, \"notes\": \"No numeric columns for anomaly detection.\"}\n",
    "\n",
    "    for col in num_df.columns:\n",
    "        series = num_df[col]\n",
    "        mean = series.mean()\n",
    "        std = series.std()\n",
    "        if std == 0 or std != std:\n",
    "            continue\n",
    "        z_scores = (series - mean) / std\n",
    "        outlier_idx = z_scores[abs(z_scores) > z_thresh].index.tolist()\n",
    "        anomalies[col] = {\n",
    "            \"mean\": float(mean),\n",
    "            \"std\": float(std),\n",
    "            \"z_threshold\": z_thresh,\n",
    "            \"outlier_count\": len(outlier_idx),\n",
    "            \"outlier_indices\": outlier_idx[:100],  # cap for readability\n",
    "        }\n",
    "\n",
    "    return {\"columns\": anomalies}\n"
   ]
  },
