    "def build_text_context_for_llm(metadata: Dict[str, Any],\n",
    "                               analytics: Dict[str, Any]) -> str:\n",
    "    \"\"\"Convert metadata + analytics to a readable text context for the LLM.\"\"\"\n",
    "    lines: List[str] = []\n",
    "\n",
    "    # ---- Metadata ----\n",
    "    shape = metadata.get(\"shape\", {})\n",
    "    lines.append(\"=== DATASET METADATA ===\")\n",
    "    lines.append(f\"Rows: {shape.get('rows')}, Columns: {shape.get('columns')}\")\n",
    "    lines.append(f\"Columns: {', '.join(metadata.get('columns', []))}\")\n",
    "    lines.append(\"Dtypes:\")\n",
    "    for col, dt_ in metadata.get(\"dtypes\", {}).items():\n",
    "        lines.append(f\"  - {col}: {dt_}\")\n",
    "\n",
    "    lines.append(\"\\nMissing values (%):\")\n",
    "    for col, pct in metadata.get(\"missing_pct\", {}).items():\n",
    "        lines.append(f\"  - {col}: {pct}%\")\n",
    "\n",
    "    lines.append(f\"\\nDuplicate rows: {metadata.get('duplicate_count')} \"\n",
    "                 f\"({metadata.get('duplicate_pct')}%)\")\n",
    "\n",
    "    # ---- KPI Summary ----\n",
    "    kpis = analytics.get(\"kpis\", {})\n",
    "    lines.append(\"\\n=== KPI ENGINE (NUMERIC) ===\")\n",
    "    for col, stats in kpis.get(\"numeric_stats\", {}).items():\n",
    "        lines.append(\n",
    "            f\"- {col}: mean={stats['mean']}, median={stats['median']}, \"\n",
    "            f\"min={stats['min']}, max={stats['max']}, sum={stats['sum']}, \"\n",
    "            f\"std={stats['std']}, non_null={stats['non_null_count']}\"\n",
    "        )\n",
    "\n",
    "    lines.append(\"\\n=== KPI ENGINE (CATEGORICAL) ===\")\n",
    "    for col, stats in kpis.get(\"categorical_stats\", {}).items():\n",
    "        lines.append(\n",
    "            f\"- {col}: unique_count={stats['unique_count']}, \"\n",
    "            f\"top_values={stats['top_values']}\"\n",
    "        )\n",
    "\n",
    "    # ---- Trends ----\n",
    "    trends = analytics.get(\"trends\", {})\n",
    "    dt_col = trends.get(\"datetime_column\")\n",
    "    lines.append(\"\\n=== TREND ANALYZER ===\")\n",
    "    if dt_col is None:\n",
    "        lines.append(\"No reliable datetime column detected – trend analysis limited.\")\n",
    "    else:\n",
    "        lines.append(f\"Datetime column used: {dt_col}\")\n",
    "        monthly = trends.get(\"monthly\", {}).get(\"data\", [])[:12]\n",
    "        weekly = trends.get(\"weekly\", {}).get(\"data\", [])[:12]\n",
    "        lines.append(\"Monthly aggregates (first up to 12 points):\")\n",
    "        lines.append(str(monthly))\n",
    "        lines.append(\"Weekly aggregates (first up to 12 points):\")\n",
    "        lines.append(str(weekly))\n",
    "\n",
    "    # ---- Anomalies ----\n",
    "    anomalies = analytics.get(\"anomalies\", {}).get(\"columns\", {})\n",
    "    lines.append(\"\\n=== ANOMALY DETECTOR ===\")\n",
    "    if not anomalies:\n",
    "        lines.append(\"No anomalies detected or no numeric data.\")\n",
    "    else:\n",
    "        for col, info in anomalies.items():\n",
    "            lines.append(\n",
    "                f\"- {col}: mean={info['mean']}, std={info['std']}, \"\n",
    "                f\"z_threshold={info['z_threshold']}, \"\n",
    "                f\"outlier_count={info['outlier_count']}\"\n",
    "            )\n",
    "\n",
    "    return \"\\n\".join(lines)\n"
   ]
  },
