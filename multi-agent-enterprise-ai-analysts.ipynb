    "def layer3_multi_agent_reasoning(\n",
    "    llm_client: RealLLMClient,\n",
    "    metadata: Dict[str, Any],\n",
    "    analytics: Dict[str, Any],\n",
    ") -> Dict[str, Any]:\n",
    "    \"\"\"Layer 3 – run EDA Agent, ML Agent, and Narrative/BI Agent.\"\"\"\n",
    "    context_text = build_text_context_for_llm(metadata, analytics)\n",
    "\n",
    "    # 1) EDA Agent\n",
    "    eda_report_md = call_agent(\n",
    "        llm_client=llm_client,\n",
    "        system_prompt=EDA_AGENT_SYSTEM_PROMPT,\n",
    "        context_text=context_text,\n",
    "        extra_instruction=\"Act strictly as the EDA Agent.\",\n",
    "    )\n",
    "\n",
    "    # 2) ML Agent (we can optionally feed EDA summary inside extra_instruction)\n",
    "    ml_report_md = call_agent(\n",
    "        llm_client=llm_client,\n",
    "        system_prompt=ML_AGENT_SYSTEM_PROMPT,\n",
    "        context_text=context_text + \"\\n\\n[EDA SUMMARY]\\n\" + eda_report_md,\n",
    "        extra_instruction=\"Act strictly as the ML Strategy Agent.\",\n",
    "    )\n",
    "\n",
    "    # 3) Narrative / BI / Internship Agent\n",
    "    narrative_report_md = call_agent(\n",
    "        llm_client=llm_client,\n",
    "        system_prompt=NARRATIVE_BI_AGENT_SYSTEM_PROMPT,\n",
    "        context_text=(\n",
    "            context_text\n",
    "            + \"\\n\\n[EDA SUMMARY]\\n\"\n",
    "            + eda_report_md\n",
    "            + \"\\n\\n[ML SUMMARY]\\n\"\n",
    "            + ml_report_md\n",
    "        ),\n",
    "        extra_instruction=(\n",
    "            \"Act strictly as the Narrative / BI Agent with focus on \"\n",
    "            \"Power BI, Fabric, and internship portfolio storytelling.\"\n",
    "        ),\n",
    "    )\n",
    "\n",
    "    # For compatibility, we can also create a combined \"executive_report\"\n",
    "    combined_markdown = (\n",
    "        \"# Enterprise AI Analyst Multi-Agent Report\\n\\n\"\n",
    "        \"## A. EDA Agent Summary\\n\\n\"\n",
    "        + eda_report_md\n",
    "        + \"\\n\\n## B. ML Strategy Agent Summary\\n\\n\"\n",
    "        + ml_report_md\n",
    "        + \"\\n\\n## C. Narrative / BI Agent Summary\\n\\n\"\n",
    "        + narrative_report_md\n",
    "    )\n",
    "\n",
    "    return {\n",
    "        \"eda_report_markdown\": eda_report_md,\n",
    "        \"ml_report_markdown\": ml_report_md,\n",
    "        \"narrative_report_markdown\": narrative_report_md,\n",
    "        \"combined_markdown\": combined_markdown,\n",
    "    }\n"
   ]
  },
