    "def call_agent(\n",
    "    llm_client: RealLLMClient,\n",
    "    system_prompt: str,\n",
    "    context_text: str,\n",
    "    extra_instruction: str = \"\"\n",
    ") -> str:\n",
    "    \"\"\"Generic helper to call a specific agent with context.\"\"\"\n",
    "    user_prompt = f\"\"\"\n",
    "You are given the following dataset context, metadata, KPIs, trends, and anomaly info:\n",
    "\n",
    "---------------- DATA CONTEXT START ----------------\n",
    "{context_text}\n",
    "---------------- DATA CONTEXT END ----------------\n",
    "\n",
    "{extra_instruction}\n",
    "\"\"\"\n",
    "    return llm_client.generate(system_prompt=system_prompt, user_prompt=user_prompt)\n"
   ]
  },
